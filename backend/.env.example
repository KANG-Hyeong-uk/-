# Trust Backend Environment Variables — EC2 1-tier 배포용

# PostgreSQL (docker-compose의 db 서비스)
POSTGRES_PASSWORD=your-strong-password
# DATABASE_URL은 docker-compose에서 자동 조합됨 (직접 실행 시 아래 주석 해제)
# DATABASE_URL=postgresql://trust:your-strong-password@localhost:5432/trust

# JWT 서명 키 (랜덤 32자 이상 문자열)
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# Gemini API
GEMINI_API_KEY=AIzaSy-your-key

# 앱 설정
ENVIRONMENT=production
ALLOWED_ORIGINS=https://your-frontend-domain.com

# 알림 (선택)
RESEND_API_KEY=

# GitHub OAuth (선택)
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Vercel OAuth (선택)
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=

# Paddle 결제 (선택)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_MONTHLY=
PADDLE_PRICE_YEARLY=
PADDLE_DISCOUNT_ID=

# Web Push VAPID (선택)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:contact@trust-scan.me

# 관리자 시크릿
ADMIN_SECRET=your-admin-secret
